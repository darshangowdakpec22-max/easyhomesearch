# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database (Supabase / any PostgreSQL) ─────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/easyhomesearch
# Set to "true" when connecting to Supabase (requires SSL)
DATABASE_SSL=false

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcards)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
